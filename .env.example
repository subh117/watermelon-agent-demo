# GitHub Personal Access Token.
# Required scopes for a private repo: repo
# Required permissions for a fine-grained token: Issues read/write, Metadata read, Contents read.
GITHUB_TOKEN=ghp_replace_me

# Repository where the demo should run. Use a disposable test repo.
GITHUB_REPO=your-github-username/watermelon-agent-demo

# Optional. Default: .agent_memory.sqlite
AGENT_MEMORY_PATH=.agent_memory.sqlite

# Optional. Default: runs
AGENT_REPORT_DIR=runs
